# ============================================
# DJANGO CORE SETTINGS
# ============================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ============================================
# DATABASE
# ============================================
# SQLite (default for development - no config needed)

# PostgreSQL (for production - uncomment when ready)
# DB_NAME=zunto_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Zunto <noreply@zunto.com>
ADMIN_EMAIL=admin@zunto.com

# ============================================
# PAYSTACK PAYMENT GATEWAY
# ============================================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ============================================
# AI ASSISTANT - GROQ API (MAIN)
# ============================================
***REMOVED***=***REMOVED***5GeKxEt9aGcsCHWJZj7GWGdyb3FYJigoux3eyKzOe0ZweIq21AUT
GROQ_MODEL=llama-3.3-70b-versatile
# ============================================
# FAQ MATCHING (LOCAL SEMANTIC SEARCH)
# ============================================
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-mpnet-base-v2
FAQ_MATCH_THRESHOLD=0.55  # Or 0.55, whatever you prefer

# ============================================
# DEPRECATED - OLD GPT4ALL (NO LONGER USED)
# ============================================
# GPT4ALL_MODEL_PATH=c:\zunto_model\mistral-7b-openorca.Q4_0.gguf
