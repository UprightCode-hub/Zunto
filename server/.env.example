# Runtime / deployment
RENDER=
PRODUCTION=False
RENDER_FREE_TIER=False
DEBUG=True
PYTHON_VERSION=3.12.8
SECRET_KEY=dev-secret-key-change-me-in-production

# Public URLs and browser security
BACKEND_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Database / cache / async
DATABASE_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Zunto <noreply@zunto.com>
ADMIN_EMAIL=admin@zunto.com
EMAIL_USE_CONSOLE_IN_DEBUG=False

# Payments
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYMENT_ALLOWED_CALLBACK_HOSTS=localhost,127.0.0.1

# AI / assistant
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=8
GROQ_BULKHEAD_LIMIT=16
GROQ_RATE_LIMIT_COOLDOWN_SECONDS=30
LLM_MAX_PROMPT_TOKENS=900
LLM_MAX_OUTPUT_TOKENS=500
FAQ_MATCH_THRESHOLD=0.5
PRODUCT_VECTOR_BACKEND=auto
EMBEDDING_MODEL=all-MiniLM-L12-v2
PRODUCT_VECTOR_DIMENSIONS=384
PRODUCT_VECTOR_TABLE=
PRODUCT_RECOMMENDER_CANDIDATE_LIMIT=1000
HOMEPAGE_RECO_SESSION_TTL_MINUTES=20
ASSISTANT_PRELOAD_DATA=True
AI_COMPONENTS_DISABLED=False
RECO_FEED_CATEGORY_WEIGHT=1.15
RECO_FEED_BUDGET_WEIGHT=1.1
RECO_BEHAVIOR_AGGREGATION_MINUTES=15

# Phase-one assistant toggles
PHASE1_UNIFIED_CONFIDENCE=True
PHASE1_CONTEXT_INTEGRATION=True
PHASE1_INTENT_CACHING=True
PHASE1_LLM_CONTEXT_ENRICHMENT=True
PHASE1_RESPONSE_PERSONALIZATION_FIX=True

# Chat and auth
CHAT_HMAC_SECRET=change-me-in-production
CHAT_BLOCKED_LINK_DOMAINS=grabify.link,bit.ly,tinyurl.com,is.gd,cutt.ly,rebrand.ly
GOOGLE_OAUTH_CLIENT_ID=

# Upload malware scanning
MALWARE_SCAN_ENABLED=False
MALWARE_SCAN_BACKEND=clamav
MALWARE_SCAN_FAIL_CLOSED=False
MALWARE_SCAN_CLAMAV_HOST=127.0.0.1
MALWARE_SCAN_CLAMAV_PORT=3310
MALWARE_SCAN_TIMEOUT_SECONDS=5
MALWARE_QUARANTINE_ON_DETECT=True
MALWARE_QUARANTINE_DIR=

# Observability and health alerts
SLOW_REQUEST_THRESHOLD_MS=1500
HEALTH_ALERT_ACTIVE_TASKS_THRESHOLD=100
HEALTH_ALERT_SCHEDULED_TASKS_THRESHOLD=200
HEALTH_ALERT_RESERVED_TASKS_THRESHOLD=100
HEALTH_ALERT_REDIS_QUEUE_DEPTH_THRESHOLD=500
HEALTH_ALERT_NOTIFY_EMAIL_ENABLED=False
HEALTH_ALERT_NOTIFY_EMAIL_COOLDOWN_SECONDS=900
HEALTH_ALERT_RECIPIENTS=
HEALTH_ALERT_NOTIFY_WEBHOOK_ENABLED=False
HEALTH_ALERT_WEBHOOK_URL=
HEALTH_ALERT_NOTIFY_WEBHOOK_COOLDOWN_SECONDS=300
HEALTH_REDIS_QUEUE_NAMES=celery

# Optional media URL hints for absolute media links
