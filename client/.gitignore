# ==============================
.env
*.env
*.key
*.pem

# ==============================
# 📦 Node / Frontend
# ==============================
node_modules/
dist/
dist-ssr/
build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

*.local

