# ==============================
# 🐍 Python / Django
# ==============================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.sqlite3
db.sqlite3
*.log

# Virtual environments
venv/
.env/
.env.*

# Django generated files
staticfiles/
media/
static_cdn/media_root/

# ==============================
